# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend-domain.com

# ── Gemini API ─────────────────────────────────────────────────────────────────
# Get your free key at: https://aistudio.google.com/app/apikey
# (Optional) Comma-separated list of VIP keys for the Admin ONLY. 
# Bypasses the default key to ensure admin always has quota.
# VIP_GEMINI_API_KEYS="key1,key2,key3"
GEMINI_API_KEY=your_gemini_api_key_here

# ── Groq API (optional — enables Groq models) ─────────────────────────────────
# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── OpenRouter API (optional — enables DeepSeek, Llama 3, etc.) ────────────────
# Get your free key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# Steps to get these values:
# 1. Go to Firebase Console → Project Settings → Service Accounts
# 2. Click "Generate new private key" → Download the JSON file
# 3. Copy the values below from that JSON file
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# Note: Keep the quotes! The private key has newlines that must be preserved.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── Firebase App Check ────────────────────────────────────────────────────────
# Set to true for LOCAL DEVELOPMENT ONLY. Never true in production.
# In production, remove this line (or set to false) — App Check is enforced.
SKIP_APP_CHECK=true

# ── Email (Nodemailer + Gmail) ─────────────────────────────────────────────────
# Your Gmail address — admin access request notifications are sent to this email.
ADMIN_EMAIL=your_gmail@gmail.com
# Gmail App Password (NOT your regular Gmail password):
# Google Account → Security → 2FA → App passwords → Create one named "OnePoint AI"
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Frontend URL (for email deep links) ──────────────────────────────────────
# Used to generate clickable links in admin notification emails.
# Local dev:  http://localhost:3000
# Production: https://your-production-domain.com
FRONTEND_URL=http://localhost:3000

# ── Admin UID ────────────────────────────────────────────────────────────────
# Your Firebase UID — found in Firebase Console → Authentication → Users
# Run 'node backend/scripts/seedAdmin.js' after setting this.
ADMIN_UID=your_firebase_uid_here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
ALLOWED_ORIGINS=http://localhost:3000

# ── Gemini API ─────────────────────────────────────────────────────────────────
# Get your free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Groq API (optional — enables Groq models) ─────────────────────────────────
# Get your free key at: https://console.groq.com/keys
# If not set, Groq models will be unavailable but Gemini models will still work.
GROQ_API_KEY=your_groq_api_key_here

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# Steps to get these values:
# 1. Go to Firebase Console → Project Settings → Service Accounts
# 2. Click "Generate new private key" → Download the JSON file
# 3. Copy the values below from that JSON file

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# Note: Keep the quotes! The private key has newlines that must be preserved.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

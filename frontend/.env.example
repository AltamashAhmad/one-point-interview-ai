REACT_APP_FIREBASE_API_KEY=your_firebase_api_key
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
REACT_APP_FIREBASE_APP_ID=your_app_id

# Backend URL
REACT_APP_BACKEND_URL=http://localhost:8080

# ── Firebase App Check ──────────────────────────────────────────────────────
# LOCAL DEVELOPMENT — set this to true to use debug token mode (no reCAPTCHA needed)
# On first load, check the browser console for the debug token.
# Register that token in: Firebase Console → App Check → [your app] → Debug tokens
REACT_APP_FIREBASE_APPCHECK_DEBUG_TOKEN=true

# PRODUCTION — comment out the line above and fill in your reCAPTCHA v3 site key.
# Get it from: https://www.google.com/recaptcha/admin
# Choose reCAPTCHA v3, add your production domain.
# REACT_APP_RECAPTCHA_SITE_KEY=your_recaptcha_v3_site_key_here

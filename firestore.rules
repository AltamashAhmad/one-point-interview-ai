rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ──────────────────────────────────────────────────────

    // Is the request from a logged-in Firebase user?
    function isAuth() {
      return request.auth != null;
    }

    // Is the requesting user the owner of this document?
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // Is the requesting user an admin?
    // Reads from the users collection — cannot be spoofed by the client.
    function isAdmin() {
      return isAuth()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── users collection ──────────────────────────────────────────────────────
    match /users/{uid} {
      // A user may read their own profile. Admins can read any profile.
      allow read: if isOwner(uid) || isAdmin();

      // A user may create their own profile only on first sign-up.
      // They CANNOT self-assign admin role, APPROVED status, or unlimited access.
      allow create: if isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.role == 'user'
        && request.resource.data.status == 'PENDING'
        && request.resource.data.isUnlimited == false
        && !request.resource.data.keys().hasAny(['approvedAt', 'approvedBy', 'banReason']);

      // Only admins may update user profiles (status, role, quotas, bans, etc.)
      allow update: if isAdmin();

      // Only admins may delete user profiles.
      allow delete: if isAdmin();
    }

    // ── interviews collection ─────────────────────────────────────────────────
    match /interviews/{docId} {
      // Users can only access their own interviews. Admins can access all.
      allow read:   if isAuth() && resource.data.userId == request.auth.uid || isAdmin();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && resource.data.userId == request.auth.uid || isAdmin();
      allow delete: if isAuth() && resource.data.userId == request.auth.uid || isAdmin();
    }

    // ── loops collection ──────────────────────────────────────────────────────
    match /loops/{docId} {
      allow read:   if isAuth() && resource.data.userId == request.auth.uid || isAdmin();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && resource.data.userId == request.auth.uid || isAdmin();
      allow delete: if isAuth() && resource.data.userId == request.auth.uid || isAdmin();
    }

    // ── accessRequests collection ─────────────────────────────────────────────
    match /accessRequests/{docId} {
      // Any authenticated user can CREATE their own access request.
      // They cannot read others' requests or modify/delete existing ones.
      allow create: if isAuth()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == 'pending';

      // Only admins can read, update, and delete access requests.
      allow read, update, delete: if isAdmin();
    }

    // ── platformSettings collection ───────────────────────────────────────────
    match /platformSettings/{docId} {
      // Any authenticated user can read settings (e.g. maintenance mode banner).
      allow read: if isAuth();
      // Only admins can update settings.
      allow write: if isAdmin();
    }

    // ── Catch-all: deny everything else ───────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
